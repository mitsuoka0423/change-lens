{
  "name": "change-lens",
  "displayName": "Change Lens",
  "description": "Highlight lines changed by open pull requests directly in the editor",
  "version": "0.0.1",
  "publisher": "mitsuoka0423",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "changeLens.refresh",
        "title": "Change Lens: Refresh Highlights"
      },
      {
        "command": "changeLens.openPr",
        "title": "Change Lens: Open PR in Browser"
      }
    ],
    "configuration": {
      "title": "Change Lens",
      "properties": {
        "changeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "ハイライト表示の有効/無効"
        },
        "changeLens.currentUser": {
          "type": "string",
          "default": "",
          "description": "自分のGitHubユーザー名（設定すると自分のPRを除外）"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:production": "node esbuild.config.mjs --production",
    "clean": "rm -rf dist",
    "package": "npm run build:production && vsce package --no-dependencies"
  },
  "dependencies": {
    "@change-lens/core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
